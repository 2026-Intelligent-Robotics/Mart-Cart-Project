<?xml version="1.0"?>
<sdf version="1.6">
  <world name="mart">

    <include>
      <uri>model://ground_plane</uri>
    </include>
    <include>
      <uri>model://sun</uri>
    </include>

    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <sor>1.4</sor>
        </solver>
        <constraints>
          <cfm>1e-5</cfm>
          <erp>0.2</erp>
        </constraints>
      </ode>
    </physics>

    <model name="boundary_walls">
      <static>true</static>
      <pose>5 3 1.25 0 0 0</pose>
      <link name="link">
        <visual name="n_v">
          <pose>0 4 0 0 0 0</pose>
          <geometry><box><size>12.0 0.1 2.5</size></box></geometry>
        </visual>
        <collision name="n_c">
          <pose>0 4 0 0 0 0</pose>
          <geometry><box><size>12.0 0.1 2.5</size></box></geometry>
        </collision>
        <visual name="e_v">
          <pose>6 0 0 0 0 1.5708</pose>
          <geometry><box><size>8.0 0.1 2.5</size></box></geometry>
        </visual>
        <collision name="e_c">
          <pose>6 0 0 0 0 1.5708</pose>
          <geometry><box><size>8.0 0.1 2.5</size></box></geometry>
        </collision>
        <visual name="w_v">
          <pose>-6 0 0 0 0 1.5708</pose>
          <geometry><box><size>8.0 0.1 2.5</size></box></geometry>
        </visual>
        <collision name="w_c">
          <pose>-6 0 0 0 0 1.5708</pose>
          <geometry><box><size>8.0 0.1 2.5</size></box></geometry>
        </collision>
        <visual name="s_v_left">
          <pose>-3.5 -4 0 0 0 0</pose>
          <geometry><box><size>5.0 0.1 2.5</size></box></geometry>
        </visual>
        <collision name="s_c_left">
          <pose>-3.5 -4 0 0 0 0</pose>
          <geometry><box><size>5.0 0.1 2.5</size></box></geometry>
        </collision>
        <visual name="s_v_right">
          <pose>3.5 -4 0 0 0 0</pose>
          <geometry><box><size>5.0 0.1 2.5</size></box></geometry>
        </visual>
        <collision name="s_c_right">
          <pose>3.5 -4 0 0 0 0</pose>
          <geometry><box><size>5.0 0.1 2.5</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- 과일 진열대 (회색) -->
    <model name="shelf_fruits_group">
      <static>true</static>
      <pose>9.0 6.5 0.4 0 0 0</pose>
      <link name="link">
        <collision name="h_c">
          <pose>0 0 0 0 0 0</pose>
          <geometry><box><size>3.0 0.6 0.8</size></box></geometry>
        </collision>
        <visual name="h_v">
          <pose>0 0 0 0 0 0</pose>
          <geometry><box><size>3.0 0.6 0.8</size></box></geometry>
          <material>
            <ambient>0.75 0.75 0.75 1</ambient>
            <diffuse>0.75 0.75 0.75 1</diffuse>
          </material>
        </visual>
        <collision name="v_c">
          <pose>1.3 -1.05 0 0 0 0</pose>
          <geometry><box><size>0.4 1.5 0.8</size></box></geometry>
        </collision>
        <visual name="v_v">
          <pose>1.3 -1.05 0 0 0 0</pose>
          <geometry><box><size>0.4 1.5 0.8</size></box></geometry>
          <material>
            <ambient>0.75 0.75 0.75 1</ambient>
            <diffuse>0.75 0.75 0.75 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- 채소 진열대 (회색) -->
    <model name="shelf_veg_group">
      <static>true</static>
      <pose>1.5 6.5 0.4 0 0 0</pose>
      <link name="link">
        <collision name="h_c">
          <pose>0 0 0 0 0 0</pose>
          <geometry><box><size>3.0 0.6 0.8</size></box></geometry>
        </collision>
        <visual name="h_v">
          <pose>0 0 0 0 0 0</pose>
          <geometry><box><size>3.0 0.6 0.8</size></box></geometry>
          <material>
            <ambient>0.75 0.75 0.75 1</ambient>
            <diffuse>0.75 0.75 0.75 1</diffuse>
          </material>
        </visual>
        <collision name="v_c">
          <pose>-1.3 -1.05 0 0 0 0</pose>
          <geometry><box><size>0.4 1.5 0.8</size></box></geometry>
        </collision>
        <visual name="v_v">
          <pose>-1.3 -1.05 0 0 0 0</pose>
          <geometry><box><size>0.4 1.5 0.8</size></box></geometry>
          <material>
            <ambient>0.75 0.75 0.75 1</ambient>
            <diffuse>0.75 0.75 0.75 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- 바나나 x2 (노란색) -->
    <model name="banana_1">
      <static>false</static>
      <pose>8.0 6.5 0.83 0 0 0</pose>
      <link name="l">
        <inertial><mass>0.1</mass></inertial>
        <collision name="c">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <material><ambient>1 1 0 1</ambient><diffuse>1 1 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="banana_2">
      <static>false</static>
      <pose>8.2 6.5 0.83 0 0 0</pose>
      <link name="l">
        <inertial><mass>0.1</mass></inertial>
        <collision name="c">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <material><ambient>1 1 0 1</ambient><diffuse>1 1 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- 사과 x2 (빨간색) -->
    <model name="apple_1">
      <static>false</static>
      <pose>9.0 6.5 0.83 0 0 0</pose>
      <link name="l">
        <inertial><mass>0.1</mass></inertial>
        <collision name="c">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="apple_2">
      <static>false</static>
      <pose>9.2 6.5 0.83 0 0 0</pose>
      <link name="l">
        <inertial><mass>0.1</mass></inertial>
        <collision name="c">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- 브로콜리 x2 (초록색) -->
    <model name="broccoli_1">
      <static>false</static>
      <pose>1.0 6.5 0.83 0 0 0</pose>
      <link name="l">
        <inertial><mass>0.1</mass></inertial>
        <collision name="c">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <material><ambient>0 0.5 0 1</ambient><diffuse>0 0.5 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="broccoli_2">
      <static>false</static>
      <pose>1.2 6.5 0.83 0 0 0</pose>
      <link name="l">
        <inertial><mass>0.1</mass></inertial>
        <collision name="c">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <material><ambient>0 0.5 0 1</ambient><diffuse>0 0.5 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- 당근 x2 (주황색) -->
    <model name="carrot_1">
      <static>false</static>
      <pose>1.8 6.5 0.83 0 0 0</pose>
      <link name="l">
        <inertial><mass>0.1</mass></inertial>
        <collision name="c">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <material><ambient>1 0.5 0 1</ambient><diffuse>1 0.5 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="carrot_2">
      <static>false</static>
      <pose>2.0 6.5 0.83 0 0 0</pose>
      <link name="l">
        <inertial><mass>0.1</mass></inertial>
        <collision name="c">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <material><ambient>1 0.5 0 1</ambient><diffuse>1 0.5 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="checkout_counter">
      <static>true</static>
      <pose>0.0 1.5 0.4 0 0 1.5708</pose>
      <link name="link">
        <collision name="c">
          <geometry><box><size>1.5 0.6 0.8</size></box></geometry>
        </collision>
        <visual name="v">
          <geometry><box><size>1.5 0.6 0.8</size></box></geometry>
          <material>
            <ambient>0.5 0.5 0.75 1</ambient>
            <diffuse>0.5 0.5 0.75 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="person">
      <pose>5.0 -1.5 0.19 0 0 -1.5708</pose>

      <link name="base">
        <inertial>
          <mass>20.0</mass>
          <inertia>
            <ixx>1.0</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>1.0</iyy><iyz>0</iyz><izz>0.5</izz>
          </inertia>
        </inertial>
        <visual name="base_v">
          <pose>0 0 0 0 0 0</pose>
          <geometry><cylinder><radius>0.3</radius><length>0.1</length></cylinder></geometry>
          <material><ambient>0.2 0.4 0.9 1</ambient><diffuse>0.2 0.4 0.9 1</diffuse></material>
        </visual>
        <collision name="base_c">
          <pose>0 0 0 0 0 0</pose>
          <geometry><cylinder><radius>0.3</radius><length>0.1</length></cylinder></geometry>
        </collision>
        <visual name="torso_v">
          <pose>0 0 0.55 0 0 0</pose>
          <geometry><box><size>0.35 0.2 0.7</size></box></geometry>
          <material><ambient>0.2 0.4 0.9 1</ambient><diffuse>0.2 0.4 0.9 1</diffuse></material>
        </visual>
        <visual name="head_v">
          <pose>0 0 1.05 0 0 0</pose>
          <geometry><sphere><radius>0.15</radius></sphere></geometry>
          <material><ambient>0.9 0.75 0.6 1</ambient><diffuse>0.9 0.75 0.6 1</diffuse></material>
        </visual>
      </link>

      <link name="left_wheel">
        <pose>0 0.3 0 1.5708 0 0</pose>
        <inertial>
          <mass>2.0</mass>
          <inertia><ixx>0.05</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.05</iyy><iyz>0</iyz><izz>0.05</izz></inertia>
        </inertial>
        <visual name="v">
          <geometry><cylinder><radius>0.15</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="c">
          <geometry><cylinder><radius>0.15</radius><length>0.05</length></cylinder></geometry>
          <surface><friction><ode><mu>10.0</mu><mu2>10.0</mu2></ode></friction></surface>
        </collision>
      </link>

      <link name="right_wheel">
        <pose>0 -0.3 0 1.5708 0 0</pose>
        <inertial>
          <mass>2.0</mass>
          <inertia><ixx>0.05</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.05</iyy><iyz>0</iyz><izz>0.05</izz></inertia>
        </inertial>
        <visual name="v">
          <geometry><cylinder><radius>0.15</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="c">
          <geometry><cylinder><radius>0.15</radius><length>0.05</length></cylinder></geometry>
          <surface><friction><ode><mu>10.0</mu><mu2>10.0</mu2></ode></friction></surface>
        </collision>
      </link>

      <link name="caster">
        <pose>0.25 0 -0.1 0 0 0</pose>
        <inertial><mass>0.5</mass></inertial>
        <visual name="v">
          <geometry><sphere><radius>0.05</radius></sphere></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material>
        </visual>
        <collision name="c">
          <geometry><sphere><radius>0.05</radius></sphere></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
        </collision>
      </link>

      <link name="caster_back">
        <pose>-0.25 0 -0.1 0 0 0</pose>
        <inertial><mass>0.5</mass></inertial>
        <visual name="v">
          <geometry><sphere><radius>0.05</radius></sphere></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material>
        </visual>
        <collision name="c">
          <geometry><sphere><radius>0.05</radius></sphere></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
        </collision>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>base</parent><child>left_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>

      <joint name="right_wheel_joint" type="revolute">
        <parent>base</parent><child>right_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>

      <joint name="caster_joint" type="fixed">
        <parent>base</parent><child>caster</child>
      </joint>

      <joint name="caster_back_joint" type="fixed">
        <parent>base</parent><child>caster_back</child>
      </joint>

      <plugin name="person_diff_drive" filename="libgazebo_ros_diff_drive.so">
        <ros><namespace>/person</namespace></ros>
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.6</wheel_separation>
        <wheel_diameter>0.3</wheel_diameter>
        <max_wheel_torque>50</max_wheel_torque>
        <max_wheel_acceleration>2.0</max_wheel_acceleration>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <odometry_frame>person_odom</odometry_frame>
        <robot_base_frame>person</robot_base_frame>
      </plugin>
    </model>

  </world>
</sdf>
